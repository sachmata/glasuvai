# ── Glasuvai Development Environment ───────────────────────────────
# Copy this to .env and adjust as needed.
# docker compose reads .env automatically.

# ── Logging ────────────────────────────────────────────────────────
RUST_LOG=info

# ── Bulletin Board ─────────────────────────────────────────────────
BB_LISTEN_ADDR=0.0.0.0:3001
BB_DB_PATH=/workspace/data/bulletin-board/bb.sqlite

# ── Voting Server ──────────────────────────────────────────────────
VS_LISTEN_ADDR=0.0.0.0:3002
VS_DB_PATH=/workspace/data/voting-server/vs.sqlite
BB_URL=http://bulletin-board:3001

# ── Identity Provider ─────────────────────────────────────────────
IDP_LISTEN_ADDR=0.0.0.0:3003

# ── Web Client (Vite) ─────────────────────────────────────────────
VITE_BB_URL=http://localhost:3001
VITE_VS_URL=http://localhost:3002
VITE_IDP_URL=http://localhost:3003
